# Image Prompt Library local configuration
# Copy to .env and edit if you want non-default local paths or ports.

# Where your private SQLite database and image files live.
# This directory is intentionally ignored by git when it is ./library.
IMAGE_PROMPT_LIBRARY_PATH=./library

# Backend API / single-service local app address.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Vite development server port used by scripts/dev.sh.
FRONTEND_PORT=5177

# Where backup archives are written by scripts/backup.sh.
BACKUP_DIR=./backups
